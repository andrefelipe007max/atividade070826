programa {
  funcao inicio() {
    inteiro c, n, s
    s = 0
    escreva("escreva um numero:\n ")
     escreva(" numero : ")
     leia(n)
      escreva("quantas vezes para repetilo: ")
      leia(c)
      enquanto(c > 0){
       s = s - 1
       c = c - 1
       escreva(" Calculando", s," \n")

      }
 
    
  }
}
